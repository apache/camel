    "CamelBatchFailed": { "index": 3, "kind": "header", "displayName": "", "group": "producer", "label": "", "required": false, "javaType": "int", "deprecated": false, "deprecationNote": "", "autowired": false, "secret": false, "description": "Failed items", "constantName": "org.apache.camel.component.batch.BatchConstants#BATCH_FAILED" },
