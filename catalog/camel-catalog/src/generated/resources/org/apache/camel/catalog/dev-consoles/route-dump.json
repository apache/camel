{
  "console": {
    "kind": "console",
    "group": "camel",
    "name": "route-dump",
    "title": "Route Dump",
    "description": "Dump route in XML, YAML, or Java DSL format",
    "deprecated": false,
    "javaType": "org.apache.camel.impl.console.RouteDumpDevConsole",
    "groupId": "org.apache.camel",
    "artifactId": "camel-console",
    "version": "4.22.0-SNAPSHOT"
  },
  "options": {
    "filter": {
      "index": 0,
      "kind": "option",
      "displayName": "Filter",
      "group": "query",
      "label": "query",
      "required": false,
      "type": "string",
      "javaType": "java.lang.String",
      "deprecated": false,
      "autowired": false,
      "secret": false,
      "description": "Filters the routes matching by route id, route uri, and source location"
    },
    "format": {
      "index": 1,
      "kind": "option",
      "displayName": "Format",
      "group": "query",
      "label": "query",
      "required": false,
      "type": "string",
