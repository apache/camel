          <xs:annotation>
            <xs:documentation xml:lang="en">
<![CDATA[
Shares the unit of work with the parent and each of the multicast exchanges. By default each multicast exchange has its
own individual unit of work. Default value: false
]]>
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
      </xs:extension>
    </xs:complexContent>
