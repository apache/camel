visibility
]]>
      </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="stickyLoadBalancer" type="tns:stickyLoadBalancerDefinition">
    <xs:annotation>
      <xs:documentation xml:lang="en">
