Encode and decode SWIFT MT messages
]]>
      </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="swiftMx" type="tns:swiftMxDataFormat">
    <xs:annotation>
      <xs:documentation xml:lang="en">
<![CDATA[
Encode and decode SWIFT MX messages
]]>
      </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="syslog" type="tns:syslogDataFormat">
    <xs:annotation>
      <xs:documentation xml:lang="en">
