]]>
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
        <xs:attribute name="trace" type="xs:string">
          <xs:annotation>
            <xs:documentation xml:lang="en">
<![CDATA[
Whether tracing is enabled on this route. Default value: false
]]>
            </xs:documentation>
          </xs:annotation>
