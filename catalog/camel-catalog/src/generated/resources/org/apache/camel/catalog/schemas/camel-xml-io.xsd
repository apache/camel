        <xs:documentation xml:lang="en">
<![CDATA[
The description for this node.
]]>
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="id" type="xs:string">
      <xs:annotation>
        <xs:documentation xml:lang="en">
<![CDATA[
The id of this node.
]]>
        </xs:documentation>
      </xs:annotation>
