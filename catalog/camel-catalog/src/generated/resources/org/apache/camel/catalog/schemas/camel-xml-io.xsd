default Camel uses the last reply as the outgoing message.
]]>
            </xs:documentation>
          </xs:annotation>
        </xs:attribute>
        <xs:attribute name="aggregationStrategyMethodName" type="xs:string">
          <xs:annotation>
            <xs:documentation xml:lang="en">
