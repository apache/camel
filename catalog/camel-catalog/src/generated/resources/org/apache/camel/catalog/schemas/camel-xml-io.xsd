]]>
      </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="setVariable" type="tns:setVariableDefinition">
    <xs:annotation>
      <xs:documentation xml:lang="en">
<![CDATA[
Sets a variable to a value computed by an expression
]]>
      </xs:documentation>
    </xs:annotation>
  </xs:element>
  <xs:element name="setVariables" type="tns:setVariablesDefinition">
    <xs:annotation>
      <xs:documentation xml:lang="en">
