<!--
    The public launcher distribution, published to Maven Central.

    Deliberately carries no native Windows bootstraps: camel-x64.exe and camel-arm64.exe are
    needed only by WinGet and ship in winget-bin.xml instead. Windows users of this archive
    invoke bin\camel.bat.
-->
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>bin</id>
    <formats>
        <format>zip</format>
        <format>tar.gz</format>
    </formats>
    <componentDescriptors>
        <componentDescriptor>src/main/assembly/launcher-content.xml</componentDescriptor>
    </componentDescriptors>
</assembly>
